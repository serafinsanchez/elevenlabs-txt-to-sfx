{
  "name": "elevenlabs-txt-to-sfx",
  "version": "0.1.0",
  "description": "Generate sound effects from a text prompt (ElevenLabs) into a Live clip slot",
  "type": "module",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts",
    "start": "tsx build.ts && extensions-cli run --temp-directory ./.tmp --storage-directory ./.storage",
    "package": "tsc --noEmit && tsx build.ts --production && extensions-cli package",
    "test": "node test/check-contract.mjs && node --import tsx --test test/config.test.mjs"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:./vendor/ableton-extensions-sdk-1.0.0-beta.0.tgz"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:./vendor/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^22.0.0",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
